APP_ENV=local
APP_NAME=ai-knowledge-system
LLM_MODEL_ID=batiai/gemma4-e2b
LLM_RUNTIME_MODEL=batiai/gemma4-e2b:q4
LLM_QUANTIZED=true
OLLAMA_URL=http://127.0.0.1:11434
EMBED_MODEL_ID=BAAI/bge-m3
EMBEDDING_URL=http://127.0.0.1:8001
EMBEDDING_DEVICE=mps
EMBEDDING_TIMEOUT_SECONDS=60
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=knowledge_chunks
SOURCES_PATH=data/sources.yaml
DATA_DIR=data
INDEX_DIR=data/index
EVAL_DIR=data/evals
MODEL_CACHE_DIR=.model_cache
CHUNK_SIZE=900
CHUNK_OVERLAP=150
MAX_QUERY_CHARS=2000
RETRIEVAL_LIMIT=5
RETRIEVAL_CANDIDATE_LIMIT=8
RETRIEVAL_SEMANTIC_WEIGHT=0.7
RETRIEVAL_LEXICAL_WEIGHT=0.3
RETRIEVAL_RRF_K=60
AGENT_MAX_STEPS=4
SQLITE_PATH=logs/telemetry.db
LOG_JSONL_PATH=logs/requests.jsonl
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ai-knowledge-system
