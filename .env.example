APP_ENV=local
APP_NAME=ai-knowledge-system
LLM_BACKEND=ollama
LLM_MODEL_ID=google/gemma-4-E4B-it
LLM_RUNTIME_MODEL=gemma4:e4b
LLM_QUANTIZED=true
OLLAMA_URL=http://localhost:11434
EMBED_MODEL_ID=BAAI/bge-m3
QDRANT_URL=http://localhost:6333
# Alternative local-only mode without Docker:
# QDRANT_URL=local:data/qdrant
QDRANT_COLLECTION=knowledge_chunks
SOURCES_PATH=data/sources.yaml
DATA_DIR=data
INDEX_DIR=data/index
MODEL_CACHE_DIR=.model_cache
CHUNK_SIZE=900
CHUNK_OVERLAP=150
SQLITE_PATH=logs/telemetry.db
LOG_JSONL_PATH=logs/requests.jsonl
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
